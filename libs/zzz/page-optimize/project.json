{
  "name": "zzz-page-optimize",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/zzz/page-optimize/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "gen-file": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "node libs/zzz/page-optimize/scripts/gen-da-seasons.mjs",
          "node libs/zzz/page-optimize/scripts/gen-sd-seasons.mjs"
        ],
        "parallel": true
      },
      "outputs": [
        "{projectRoot}/src/daSeasons_gen.json",
        "{projectRoot}/src/shiyuSeasons_gen.json"
      ]
    },
    "gen-da-file": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node libs/zzz/page-optimize/scripts/gen-da-seasons.mjs"
      },
      "outputs": ["{projectRoot}/src/daSeasons_gen.json"]
    },
    "gen-sd-file": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node libs/zzz/page-optimize/scripts/gen-sd-seasons.mjs"
      },
      "outputs": ["{projectRoot}/src/shiyuSeasons_gen.json"]
    }
  }
}
