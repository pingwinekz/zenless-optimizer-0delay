{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "Launch Chrome against localhost",
      "url": "http://localhost:4200/zenless-optimizer-0delay/",
      "webRoot": "${workspaceFolder}",
      "runtimeExecutable": "/home/endmin/.local/bin/google-chrome"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Start ZZZ dev server",
      "runtimeExecutable": "yarn",
      "runtimeArgs": ["run", "nx", "serve", "zzz-frontend"]
    }
  ],
  "compounds": [
    {
      "name": "ZZZ: Dev + Debug",
      "configurations": [
        "Start ZZZ dev server",
        "Launch Chrome against localhost"
      ]
    }
  ]
}
