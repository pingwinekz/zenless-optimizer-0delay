{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "Launch Chrome against localhost (Requires dev server to be running)",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}",
      "runtimeExecutable": "/usr/bin/helium-browser"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Start ZZZ dev server",
      "runtimeExecutable": "yarn",
      "runtimeArgs": ["run", "nx", "serve", "zzz-frontend"]
    }
  ],
  "compounds": [
    {
      "name": "ZZZ: Dev + Debug",
      "configurations": [
        "Start ZZZ dev server",
        "Launch Chrome against localhost (Requires dev server to be running)"
      ]
    }
  ]
}
